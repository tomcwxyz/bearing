    "notes": "Generated from database. 29 active models."
  },
  "scoring_methodology": {
    "description": "Each model receives per-factor scores from 0.0 to 1.0 across seven dimensions. Combined using user-defined priority weights to produce a ranked recommendation list.",
    "factors": {
      "cost": "Inverse-normalised against cheapest model. Lower cost = higher score.",
      "speed": "Based on latency tiers and inference benchmarks. 1.0 = sub-second.",
      "quality": "Composite of benchmark performance weighted toward task type. Weakest signal — will improve with outcome data.",
      "privacy": "Based on data retention policies. 1.0 = no retention, no training on inputs.",
      "sustainability": "Composite of inference_energy, training_footprint, provider_infrastructure.",
      "transparency": "Composite of open_weights, open_training_data, open_methodology, licence_openness, provider_disclosure.",
      "capability": "Binary pass/fail for hard requirements. Graduated for soft matches."
    },
    "default_weights": {
      "quality": 0.25,
      "capability": 0.2,
      "cost": 0.2,
      "transparency": 0.1,
      "privacy": 0.1,
      "sustainability": 0.1,
      "speed": 0.05
    }
  },
  "transparency_methodology": {
    "description": "Transparency scored across five dimensions, each 0.0-1.0. Composite = mean of all five.",
    "fmti_reference": "Stanford CRFM FMTI 2025. 100 indicators, 13 companies. Average: 40.69/100. IBM: 95, AI21 Labs: 72, Writer: 67, Anthropic: 37, Google: 36, Amazon: 36, OpenAI: 35, DeepSeek: 30, Meta: 30, Alibaba: 30, Mistral: 15, xAI: 14, Midjourney: 14.",
    "fmti_criticism": "EleutherAI argues FMTI measures commercial documentation rather than genuine openness, biased against open-source projects. Bearing weights actual accessibility alongside documentation.",
    "dimensions": {
      "open_weights": "1.0=fully downloadable; 0.7=with registration; 0.3=API only; 0.0=closed",
      "open_training_data": "1.0=documented+accessible; 0.7=documented not accessible; 0.3=vague; 0.0=none",
      "open_methodology": "1.0=full reproducible paper; 0.7=substantial blog/card; 0.3=marketing only; 0.0=none",
      "licence_openness": "1.0=MIT/Apache; 0.7=open with restrictions; 0.3=proprietary clear terms; 0.0=restrictive",
      "provider_disclosure": "1.0=FMTI 80+; 0.7=FMTI 50-79; 0.4=FMTI 30-49; 0.2=FMTI 15-29; 0.0=FMTI <15"
    }
  },
  "sustainability_methodology": {
    "description": "Three sub-dimensions, each 0.0-1.0. Composite = mean of available (nulls excluded).",
    "dimensions": {
      "inference_energy": "1.0=published per-query metrics; 0.8=very small/efficient; 0.6=MoE; 0.4=standard large; null=no data",
      "training_footprint": "1.0=published with offsets; 0.7=published; 0.4=estimated; 0.0=no info; null=no data",
      "provider_infrastructure": "1.0=100% renewable+heat recovery; 0.8=100% renewable; 0.6=significant commitment+reporting; 0.4=some renewable; 0.2=none; null=no data"
    }
  },
